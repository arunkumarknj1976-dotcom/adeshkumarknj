# .env.example
# To fix "Sign in to confirm you're not a bot", provide your YouTube cookies.
# 1. Install "EditThisCookie" extension in Chrome.
# 2. Go to YouTube.com and log in.
# 3. Click the extension icon and click "Export" (JSON format).
# 4. Paste the entire JSON array into the YOUTUBE_COOKIE environment variable in AI Studio Settings.
YOUTUBE_COOKIE=

# Optional: Newer bypass method using PO Token and Visitor Data
# See: https://github.com/LuanRT/YouTube.js/blob/main/examples/po-token/README.md
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=
